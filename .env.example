# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Service Role Key (for admin operations)
SUPABASE_SERVICE_ROLE_KEY=

# Stripe Configuration
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Application Configuration
APP_URL=http://localhost:3000

# B2B (Dirty Wine) base URL for business invitation links. Default: https://dirtywine.se
# NEXT_PUBLIC_B2B_APP_URL=https://dirtywine.se

# Localhost is always treated as pactwines.com (PACT/B2C). Add ?b2b=1 to the URL to view as Dirty Wine (B2B).

# Menu extraction – Starwinelist crawler (browser adapter)
# playwright = local headless Chromium (no quota). browserless = hosted Browserless.io (needs key).
# Efter clone: kör "pnpm exec playwright install chromium" (eller pnpm playwright:install).
BROWSER_ADAPTER=playwright

# Krävs endast när BROWSER_ADAPTER=browserless. Sätt ej för lokal utveckling med playwright.
BROWSERLESS_API_KEY=

# Cron: secret for /api/cron/* routes (e.g. crawl-menus). Set in Vercel for production.
CRON_SECRET=

# MCP (Claude.ai / Cursor remote): /api/mcp and /api/mcp/messages
# MCP_AUTH_MODE=api_key | oauth | dual  (default: api_key — unchanged behavior until you opt in)
MCP_AUTH_MODE=api_key
# Shared secret when MCP_AUTH_MODE is api_key or dual
MCP_API_KEY=
# Auth0 JWT when MCP_AUTH_MODE is oauth or dual (RS validates access tokens)
AUTH0_DOMAIN=
# API Identifier from Auth0 → APIs → your API (must match JWT "aud")
AUTH0_AUDIENCE=
# Optional: override canonical resource URI in RFC 9728 metadata (default: derived from request Host)
# MCP_RESOURCE_IDENTIFIER=https://pactwines.com/api/mcp
# Optional: profiles.id used as created_by for tasks/projects/goals/objectives from MCP (else first admin profile)
MCP_ACTOR_PROFILE_ID=
