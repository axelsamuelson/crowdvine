# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Service Role Key (for admin operations)
SUPABASE_SERVICE_ROLE_KEY=

# Stripe Configuration
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Application Configuration
APP_URL=http://localhost:3000

# Invite signup: simulate Vercel geo headers locally (not sent on localhost). Example: US
# DEV_GEO_COUNTRY=US

# B2B (Dirty Wine) base URL for business invitation links. Default: https://dirtywine.se
# NEXT_PUBLIC_B2B_APP_URL=https://dirtywine.se

# Localhost defaults to pactwines.com (PACT/B2C). Add ?b2b=1 to the URL to view as dirtywine.se (B2B).

# Menu extraction – Starwinelist crawler
# Preferred (Cloudflare bypass): Browserless /unblock when BROWSERLESS_API_KEY is set.
# Fallback: @sparticuz/chromium + playwright-core on Vercel (often blocked by Cloudflare).
# Local: run `pnpm playwright:install` if using Chromium without Browserless.
# USE_LOCAL_FETCH=true uses plain fetch (often 403 on Starwinelist; dev only).
# USE_LOCAL_FETCH=
# BROWSERLESS_API_KEY=
# BROWSERLESS_BASE_URL=https://chrome.browserless.io
# Local crawl without Browserless: pnpm playwright:install && pnpm crawl:local [batchSize|slug]

# Cron: secret for /api/cron/* routes (e.g. crawl-menus, extract-menus). Set in Vercel for production.
CRON_SECRET=

# Optional Slack (or compatible) webhook for menu pipeline alerts when thresholds are exceeded.
# MENU_PIPELINE_ALERT_WEBHOOK_URL=

# MCP (Claude.ai / Cursor remote): /api/mcp and /api/mcp/messages
# 21st.dev Magic MCP (Cursor UI component generation) — https://21st.dev/magic/console
TWENTY_FIRST_API_KEY=
# MCP_AUTH_MODE=api_key | oauth | dual  (default: api_key — unchanged behavior until you opt in)
MCP_AUTH_MODE=api_key
# Shared secret when MCP_AUTH_MODE is api_key or dual
MCP_API_KEY=
# Auth0 JWT when MCP_AUTH_MODE is oauth or dual (RS validates access tokens)
AUTH0_DOMAIN=
# API Identifier from Auth0 → APIs → your API (must match JWT "aud")
AUTH0_AUDIENCE=
# Optional: override canonical resource URI in RFC 9728 metadata (default: derived from request Host)
# MCP_RESOURCE_IDENTIFIER=https://pactwines.com/api/mcp

# Resend — transactional email (https://resend.com). Set in Vercel for production.
RESEND_API_KEY=

# Styr om betalningsnotifieringar skickas automatiskt
# när en pall når 100%. Sätt till false under testning,
# true när flödet är verifierat i produktion.
PALLET_AUTO_NOTIFICATIONS=false

# Instabee / Budbee Home Delivery (https://integration.instabee.com)
INSTABEE_API_KEY=
INSTABEE_CUSTOMER_NUMBER=
# Set to true to create Instabee orders + labels after Stripe payment_intent.succeeded
INSTABEE_AUTO_CREATE_ORDERS=false

# Last-mile home delivery (Budbee) in öre per bottle. Added to pallet linehaul in checkout shipping total.
# Example: 833 = 8,33 kr/bottle. Per-pallet override: pallets.last_mile_cost_cents_per_bottle
LAST_MILE_COST_CENTS_PER_BOTTLE=833
# Optional full RFC From header; must be a verified sender/domain in Resend.
# RESEND_FROM=PACT <orders@yourdomain.com>
# Optional: profiles.id used as created_by for tasks/projects/goals/objectives from MCP (else first admin profile)
MCP_ACTOR_PROFILE_ID=
